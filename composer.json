{
    "name": "cecytebcs/sicv",
    "description": "Sistema Integral de Control Vehicular - CECYTE BCS",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "phpoffice/phpspreadsheet": "^2.0",
        "dompdf/dompdf": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/helpers/functions.php",
            "app/helpers/FileUploader.php"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform-check": false,
        "platform": {
            "php": "8.2.12"
        }
    }
}
